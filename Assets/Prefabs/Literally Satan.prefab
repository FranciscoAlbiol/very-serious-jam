  blocks:
  - index: 0
    lines:
    - characterName: Actually Satan
      characterRenderer: {fileID: 4978229224836480538}
      characterSprite: {fileID: 385089550, guid: c10126163360e254796429d030df7348, type: 3}
      text: "Hey what\u2019s up, I\u2019m actually Satan."
      voiceLine: {fileID: 8300000, guid: 5e563aca74533a8499bdbc65c0d59102, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Actually Satan
      characterRenderer: {fileID: 4978229224836480538}
      characterSprite: {fileID: 385089550, guid: c10126163360e254796429d030df7348, type: 3}
      text: Did you know I invented gambling?
      voiceLine: {fileID: 8300000, guid: 5e563aca74533a8499bdbc65c0d59102, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Actually Satan
      characterRenderer: {fileID: 4978229224836480538}
      characterSprite: {fileID: 385089550, guid: c10126163360e254796429d030df7348, type: 3}
      text: The very first gambling.
      voiceLine: {fileID: 8300000, guid: 5e563aca74533a8499bdbc65c0d59102, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Actually Satan
      characterRenderer: {fileID: 4978229224836480538}
      characterSprite: {fileID: 385089550, guid: c10126163360e254796429d030df7348, type: 3}
      text: Gambling number one.
      voiceLine: {fileID: 8300000, guid: 5e563aca74533a8499bdbc65c0d59102, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Actually Satan
      characterRenderer: {fileID: 4978229224836480538}
      characterSprite: {fileID: 385089550, guid: c10126163360e254796429d030df7348, type: 3}
      text: Out of all the gamblings.
      voiceLine: {fileID: 8300000, guid: 5e563aca74533a8499bdbc65c0d59102, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Actually Satan
      characterRenderer: {fileID: 4978229224836480538}
      characterSprite: {fileID: 385089550, guid: c10126163360e254796429d030df7348, type: 3}
      text: I made the first one.
      voiceLine: {fileID: 8300000, guid: 5e563aca74533a8499bdbc65c0d59102, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Actually Satan
      characterRenderer: {fileID: 4978229224836480538}
      characterSprite: {fileID: 385089550, guid: c10126163360e254796429d030df7348, type: 3}
      text: Pretty cool huh.
      voiceLine: {fileID: 8300000, guid: 5e563aca74533a8499bdbc65c0d59102, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
