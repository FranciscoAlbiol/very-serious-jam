  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  blocks:
  - index: 0
    lines:
    - characterName: Cuatro
      characterRenderer: {fileID: 3830917958110155178}
      characterSprite: {fileID: 1754831656, guid: fe808e723ede5dd4194ec8272d4e60af, type: 3}
      text: "\u201CCuatro\u201D is actually the correct way to spell four in Spanish,
        but the game is called Quatro because the devs, and I quote, thought it \u201Csounds
        cooler this way\u201D."
      voiceLine: {fileID: 8300000, guid: 70b43ff2426f33242ace6d33c624eeed, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cuatro
      characterRenderer: {fileID: 3830917958110155178}
      characterSprite: {fileID: 1754831656, guid: fe808e723ede5dd4194ec8272d4e60af, type: 3}
      text: "Thanks to them I can\u2019t share a name with my favourite game. Awful."
      voiceLine: {fileID: 8300000, guid: 70b43ff2426f33242ace6d33c624eeed, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
