--- !u!114 &6992783270692167930
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2851865871453379517}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c0bd1c51ddf2d9847a19ca313f37c649, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  blocks:
  - index: 0
    lines:
    - characterName: Cubestack Top
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: -189615041, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: "Oh!! Middle, look!! A new customer!~ \\ (\uFF20^\u2207^\uFF20) /"
      voiceLine: {fileID: 8300000, guid: e38d0ea8893cbfe4cb970df5cb64d37a, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Middle
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: 827081882, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: "Hey there, pard\u2019ner. Welcome ta\u2019 Cubestack\u2019s Wacky Drinks."
      voiceLine: {fileID: 8300000, guid: b5eb60947e1007f4e8ed7f6645140363, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Middle
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: 827081882, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: "Not to be confused with Face\u2019s bar, we run an\u2019 independent
        business \u2018ere."
      voiceLine: {fileID: 8300000, guid: b5eb60947e1007f4e8ed7f6645140363, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Middle
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: 827081882, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: "Whaddo we sell, ya\u2019 ask? Well, it\u2019s simple. We sell magical
        drinks that\u2019ll help ya\u2019 get luckier an\u2019 win bigger.. Just
        don\u2019t tell Mistah Nobody about it."
      voiceLine: {fileID: 8300000, guid: b5eb60947e1007f4e8ed7f6645140363, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Middle
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: 827081882, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: "Anywho, I\u2019m Middle. Pleasure to meetcha."
      voiceLine: {fileID: 8300000, guid: b5eb60947e1007f4e8ed7f6645140363, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Top
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: -189615041, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: "And I\u2019m Top!!!~~ (=^\uFF65\u03C9\uFF65^=)\u4E3F"
      voiceLine: {fileID: 8300000, guid: e38d0ea8893cbfe4cb970df5cb64d37a, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Bottom
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: -510332901, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: quack.
      voiceLine: {fileID: 8300000, guid: 4ec7b7404edac184793dbd801b31d3df, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Middle
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: 827081882, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: "And das\u2019 Bottom for ya."
      voiceLine: {fileID: 8300000, guid: b5eb60947e1007f4e8ed7f6645140363, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Middle
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: 827081882, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: "In the shelves ya\u2019 got a bunch o\u2019 colorful drinks. Just point
        to the one ya\u2019 want an\u2019, if ya\u2019 got enough cash, I\u2019ll
        fetch it for ya\u2019."
      voiceLine: {fileID: 8300000, guid: b5eb60947e1007f4e8ed7f6645140363, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Top
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: 827081882, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: "Yes, gambler-san!! We will help you get very lucky and very strong,
        nya!~\u2730  \u0B67( , \uFF3E \uFF3E , )\u0B68"
      voiceLine: {fileID: 8300000, guid: e38d0ea8893cbfe4cb970df5cb64d37a, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Cubestack Bottom
      characterRenderer: {fileID: 4065552838869054399}
      characterSprite: {fileID: -510332901, guid: 08652fc430580ab4fb596b97c97f5024, type: 3}
      text: quack.
      voiceLine: {fileID: 8300000, guid: 4ec7b7404edac184793dbd801b31d3df, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    hasChoice: 0
    choice:
      optionA:
        label: 
        onChosen:
          m_PersistentCalls:
            m_Calls: []
        nextIndex: 0
      optionB:
        label: 
        onChosen:
          m_PersistentCalls:
            m_Calls: []
        nextIndex: 0
    continueToNextBlock: 0
    nextBlockIndex: 0
  currentIndex: 0
