  m_Script: {fileID: 11500000, guid: c0bd1c51ddf2d9847a19ca313f37c649, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  blocks:
  - index: 0
    lines:
    - characterName: Trish
      characterRenderer: {fileID: 6795859856235045851}
      characterSprite: {fileID: 607759894, guid: 3c96f6c5939eeb6448d79ad90a0e3ee2, type: 3}
      text: "I- I- Is\u2026 Is this hand good\u2026?"
      voiceLine: {fileID: 8300000, guid: feb43f4053b1e7344b239d32e4b67f57, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Creepball
      characterRenderer: {fileID: 6795859856235045851}
      characterSprite: {fileID: -900877823, guid: 3c96f6c5939eeb6448d79ad90a0e3ee2, type: 3}
      text: "\u2026No. Not at all, actually. Fold now."
      voiceLine: {fileID: 8300000, guid: 268403b5bb4b6d14d9d473eaeae8949d, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Trish
      characterRenderer: {fileID: 6795859856235045851}
      characterSprite: {fileID: 607759894, guid: 3c96f6c5939eeb6448d79ad90a0e3ee2, type: 3}
      text: "I- I- Uh- What is\u2026 What does\u2026 F- F-"
      voiceLine: {fileID: 8300000, guid: feb43f4053b1e7344b239d32e4b67f57, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Trish
      characterRenderer: {fileID: 6795859856235045851}
      characterSprite: {fileID: 607759894, guid: 3c96f6c5939eeb6448d79ad90a0e3ee2, type: 3}
      text: "Fold? What is\u2026 Whuh\u2026 What is\u2026 fold?"
      voiceLine: {fileID: 8300000, guid: feb43f4053b1e7344b239d32e4b67f57, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
    - characterName: Creepball
      characterRenderer: {fileID: 6795859856235045851}
      characterSprite: {fileID: -900877823, guid: 3c96f6c5939eeb6448d79ad90a0e3ee2, type: 3}
      text: "\u2026Yeah, we\u2019re done for."
      voiceLine: {fileID: 8300000, guid: 268403b5bb4b6d14d9d473eaeae8949d, type: 3}
      onLineFinished:
        m_PersistentCalls:
          m_Calls: []
